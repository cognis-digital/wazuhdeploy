# wazuhdeploy example: multi-node configuration.
# Maintainer: Cognis Digital. License: COCL 1.0

STACK_NAME=wazuh-prod
DEPLOY_MODE=multi-node
DATA_DIR=/srv/wazuh-data
WAZUH_VERSION=4.9.0
INDEXER_NODES=3

INDEXER_PORT=9200
DASHBOARD_PORT=443
MANAGER_API_PORT=55000
AGENT_REGISTRATION_PORT=1515
AGENT_EVENTS_PORT=1514

INDEXER_HOST=wazuh.indexer
MANAGER_HOST=wazuh.manager
DASHBOARD_HOST=wazuh.dashboard
DASHBOARD_USER=kibanaserver
