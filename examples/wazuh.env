# wazuhdeploy example configuration.
# Maintainer: Cognis Digital. License: COCL 1.0
#
# Copy this file, edit the values, and pass it to wazuhdeploy.sh via --config.
# Lines beginning with '#' are comments. KEY=VALUE, one per line.

# Logical name for the stack (used as the compose project name + network).
STACK_NAME=wazuh

# Deployment topology: single-node | multi-node
DEPLOY_MODE=single-node

# Host directory where bind-mounted data + config will live.
DATA_DIR=./wazuh-data

# Wazuh image tag for manager / indexer / dashboard.
WAZUH_VERSION=4.9.0

# Number of indexer nodes you intend to run.
# single-node => 1 ; multi-node => 3 or more (quorum).
INDEXER_NODES=1

# Host-published ports. Each must be unique.
INDEXER_PORT=9200
DASHBOARD_PORT=443
MANAGER_API_PORT=55000
AGENT_REGISTRATION_PORT=1515
AGENT_EVENTS_PORT=1514

# Service hostnames (also used as compose service names).
INDEXER_HOST=wazuh.indexer
MANAGER_HOST=wazuh.manager
DASHBOARD_HOST=wazuh.dashboard

# Dashboard / indexer service account used by the dashboard.
DASHBOARD_USER=kibanaserver
