# opensearch_dashboards.yml - base Wazuh dashboard configuration.
# Generated by wazuhdeploy. Maintainer: Cognis Digital. License: COCL 1.0
# Stack: @@STACK_NAME@@

server.host: "0.0.0.0"
server.port: 5601
opensearch.hosts: "https://@@INDEXER_HOST@@:9200"
opensearch.ssl.verificationMode: "certificate"
opensearch.username: "@@DASHBOARD_USER@@"
opensearch.requestHeadersAllowlist:
  - "securitytenant"
  - "Authorization"

opensearch_security.multitenancy.enabled: false
opensearch_security.readonly_mode.roles:
  - "kibana_read_only"

# Wazuh app -> manager API binding.
# The Wazuh dashboard plugin reads its API connection list from wazuh.yml;
# this file wires the dashboard to the indexer described in the stack.
