# docker-compose.yml for a multi-node Wazuh stack.
# Generated by wazuhdeploy. Maintainer: Cognis Digital. License: COCL 1.0
#
# This template provisions a clustered Wazuh indexer (3 seed nodes for
# quorum), a manager node, and the dashboard. Adjust INDEXER_NODES in the
# config to document your intended fleet size; the three seed nodes below
# satisfy the OpenSearch cluster-manager quorum requirement.
#
# Stack name: @@STACK_NAME@@   Wazuh version: @@WAZUH_VERSION@@
# Intended indexer nodes: @@INDEXER_NODES@@

name: "@@STACK_NAME@@"

x-indexer-common: &indexer-common
  image: "wazuh/wazuh-indexer:@@WAZUH_VERSION@@"
  restart: always
  environment: &indexer-env
    - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
    - "bootstrap.memory_lock=true"
    - "cluster.name=@@STACK_NAME@@-cluster"
    - "discovery.seed_hosts=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
    - "cluster.initial_cluster_manager_nodes=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
  ulimits:
    memlock:
      soft: -1
      hard: -1
    nofile:
      soft: 65536
      hard: 65536

services:
  @@INDEXER_HOST@@-1:
    <<: *indexer-common
    hostname: "@@INDEXER_HOST@@-1"
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
      - "bootstrap.memory_lock=true"
      - "node.name=@@INDEXER_HOST@@-1"
      - "cluster.name=@@STACK_NAME@@-cluster"
      - "discovery.seed_hosts=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
      - "cluster.initial_cluster_manager_nodes=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
    ports:
      - "@@INDEXER_PORT@@:9200"
    volumes:
      - "@@DATA_DIR@@/indexer-1-data:/var/lib/wazuh-indexer"
    networks:
      - "@@STACK_NAME@@-net"

  @@INDEXER_HOST@@-2:
    <<: *indexer-common
    hostname: "@@INDEXER_HOST@@-2"
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
      - "bootstrap.memory_lock=true"
      - "node.name=@@INDEXER_HOST@@-2"
      - "cluster.name=@@STACK_NAME@@-cluster"
      - "discovery.seed_hosts=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
      - "cluster.initial_cluster_manager_nodes=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
    volumes:
      - "@@DATA_DIR@@/indexer-2-data:/var/lib/wazuh-indexer"
    networks:
      - "@@STACK_NAME@@-net"

  @@INDEXER_HOST@@-3:
    <<: *indexer-common
    hostname: "@@INDEXER_HOST@@-3"
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
      - "bootstrap.memory_lock=true"
      - "node.name=@@INDEXER_HOST@@-3"
      - "cluster.name=@@STACK_NAME@@-cluster"
      - "discovery.seed_hosts=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
      - "cluster.initial_cluster_manager_nodes=@@INDEXER_HOST@@-1,@@INDEXER_HOST@@-2,@@INDEXER_HOST@@-3"
    volumes:
      - "@@DATA_DIR@@/indexer-3-data:/var/lib/wazuh-indexer"
    networks:
      - "@@STACK_NAME@@-net"

  @@MANAGER_HOST@@:
    image: "wazuh/wazuh-manager:@@WAZUH_VERSION@@"
    hostname: "@@MANAGER_HOST@@"
    restart: always
    depends_on:
      - "@@INDEXER_HOST@@-1"
      - "@@INDEXER_HOST@@-2"
      - "@@INDEXER_HOST@@-3"
    environment:
      - "INDEXER_URL=https://@@INDEXER_HOST@@-1:9200"
      - "FILEBEAT_SSL_VERIFICATION_MODE=full"
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 655360
        hard: 655360
    ports:
      - "@@AGENT_EVENTS_PORT@@:1514"
      - "@@AGENT_REGISTRATION_PORT@@:1515"
      - "@@MANAGER_API_PORT@@:55000"
    volumes:
      - "@@DATA_DIR@@/manager-config/ossec.conf:/wazuh-config-mount/etc/ossec.conf"
      - "@@DATA_DIR@@/manager-data:/var/ossec/data"
    networks:
      - "@@STACK_NAME@@-net"

  @@DASHBOARD_HOST@@:
    image: "wazuh/wazuh-dashboard:@@WAZUH_VERSION@@"
    hostname: "@@DASHBOARD_HOST@@"
    restart: always
    depends_on:
      - "@@INDEXER_HOST@@-1"
      - "@@MANAGER_HOST@@"
    environment:
      - "INDEXER_USERNAME=@@DASHBOARD_USER@@"
      - "WAZUH_API_URL=https://@@MANAGER_HOST@@"
      - "DASHBOARD_USERNAME=@@DASHBOARD_USER@@"
    ports:
      - "@@DASHBOARD_PORT@@:5601"
    volumes:
      - "@@DATA_DIR@@/dashboard-config:/usr/share/wazuh-dashboard/config"
    networks:
      - "@@STACK_NAME@@-net"

networks:
  "@@STACK_NAME@@-net":
    driver: bridge

volumes:
  indexer-1-data:
  indexer-2-data:
  indexer-3-data:
  manager-data:
