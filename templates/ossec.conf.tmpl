<!--
  ossec.conf - base Wazuh manager configuration.
  Generated by wazuhdeploy. Maintainer: Cognis Digital. License: COCL 1.0
  Stack: @@STACK_NAME@@   Wazuh version: @@WAZUH_VERSION@@

  This is an intentionally minimal, opinionated baseline that wires the
  manager to its agent listeners and the indexer. Tune to your environment.
-->
<ossec_config>

  <global>
    <jsonout_output>yes</jsonout_output>
    <alerts_log>yes</alerts_log>
    <logall>no</logall>
    <logall_json>no</logall_json>
    <email_notification>no</email_notification>
  </global>

  <alerts>
    <log_alert_level>3</log_alert_level>
  </alerts>

  <!-- Agent event listener (secure, encrypted). -->
  <remote>
    <connection>secure</connection>
    <port>1514</port>
    <protocol>tcp</protocol>
    <queue_size>131072</queue_size>
  </remote>

  <!-- Agent registration service. -->
  <auth>
    <disabled>no</disabled>
    <port>1515</port>
    <use_source_ip>no</use_source_ip>
    <purge>yes</purge>
    <use_password>no</use_password>
  </auth>

  <!-- Indexer / forwarder target. -->
  <indexer>
    <enabled>yes</enabled>
    <hosts>
      <host>https://@@INDEXER_HOST@@:9200</host>
    </hosts>
  </indexer>

  <!-- Core decoders/rules ship with the image. -->
  <ruleset>
    <decoder_dir>ruleset/decoders</decoder_dir>
    <rule_dir>ruleset/rules</rule_dir>
    <decoder_dir>etc/decoders</decoder_dir>
    <rule_dir>etc/rules</rule_dir>
    <list>etc/lists/audit-keys</list>
  </ruleset>

  <!-- File-integrity monitoring baseline. -->
  <syscheck>
    <disabled>no</disabled>
    <frequency>43200</frequency>
    <scan_on_start>yes</scan_on_start>
    <directories check_all="yes">/etc,/usr/bin,/usr/sbin</directories>
    <directories check_all="yes">/bin,/sbin,/boot</directories>
  </syscheck>

</ossec_config>
