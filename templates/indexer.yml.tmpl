# opensearch.yml - base Wazuh indexer configuration.
# Generated by wazuhdeploy. Maintainer: Cognis Digital. License: COCL 1.0
# Stack: @@STACK_NAME@@   Mode: @@DEPLOY_MODE@@   Nodes: @@INDEXER_NODES@@

network.host: "0.0.0.0"
node.name: "@@INDEXER_HOST@@"
cluster.name: "@@STACK_NAME@@-cluster"

# Security plugin baseline (TLS material is provisioned separately).
plugins.security.ssl.transport.enforce_hostname_verification: false
plugins.security.ssl.http.enabled: true
plugins.security.allow_default_init_securityindex: true
plugins.security.audit.type: internal_opensearch
plugins.security.enable_snapshot_restore_privilege: true
plugins.security.check_snapshot_restore_write_privileges: true
plugins.security.restapi.roles_enabled:
  - "all_access"
  - "security_rest_api_access"

# Default to single-node discovery; multi-node compose overrides this via
# environment (discovery.seed_hosts / cluster.initial_cluster_manager_nodes).
discovery.type: "single-node"

compatibility.override_main_response_version: true
