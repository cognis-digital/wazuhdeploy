# docker-compose.yml for a single-node Wazuh stack.
# Generated by wazuhdeploy. Maintainer: Cognis Digital. License: COCL 1.0
#
# Components (Wazuh open-source component model):
#   * @@MANAGER_HOST@@   - Wazuh manager (analysis engine + API + agent endpoints)
#   * @@INDEXER_HOST@@   - Wazuh indexer (OpenSearch-based search/storage)
#   * @@DASHBOARD_HOST@@ - Wazuh dashboard (web UI)
#
# Stack name: @@STACK_NAME@@   Wazuh version: @@WAZUH_VERSION@@

name: "@@STACK_NAME@@"

services:
  @@INDEXER_HOST@@:
    image: "wazuh/wazuh-indexer:@@WAZUH_VERSION@@"
    hostname: "@@INDEXER_HOST@@"
    restart: always
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
      - "bootstrap.memory_lock=true"
      - "node.name=@@INDEXER_HOST@@"
      - "discovery.type=single-node"
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "@@INDEXER_PORT@@:9200"
    volumes:
      - "@@DATA_DIR@@/indexer-data:/var/lib/wazuh-indexer"
      - "@@DATA_DIR@@/indexer-config:/usr/share/wazuh-indexer/config"
    networks:
      - "@@STACK_NAME@@-net"

  @@MANAGER_HOST@@:
    image: "wazuh/wazuh-manager:@@WAZUH_VERSION@@"
    hostname: "@@MANAGER_HOST@@"
    restart: always
    depends_on:
      - "@@INDEXER_HOST@@"
    environment:
      - "INDEXER_URL=https://@@INDEXER_HOST@@:9200"
      - "FILEBEAT_SSL_VERIFICATION_MODE=full"
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 655360
        hard: 655360
    ports:
      - "@@AGENT_EVENTS_PORT@@:1514"
      - "@@AGENT_REGISTRATION_PORT@@:1515"
      - "@@MANAGER_API_PORT@@:55000"
    volumes:
      - "@@DATA_DIR@@/manager-config/ossec.conf:/wazuh-config-mount/etc/ossec.conf"
      - "@@DATA_DIR@@/manager-data:/var/ossec/data"
    networks:
      - "@@STACK_NAME@@-net"

  @@DASHBOARD_HOST@@:
    image: "wazuh/wazuh-dashboard:@@WAZUH_VERSION@@"
    hostname: "@@DASHBOARD_HOST@@"
    restart: always
    depends_on:
      - "@@INDEXER_HOST@@"
      - "@@MANAGER_HOST@@"
    environment:
      - "INDEXER_USERNAME=@@DASHBOARD_USER@@"
      - "WAZUH_API_URL=https://@@MANAGER_HOST@@"
      - "DASHBOARD_USERNAME=@@DASHBOARD_USER@@"
    ports:
      - "@@DASHBOARD_PORT@@:5601"
    volumes:
      - "@@DATA_DIR@@/dashboard-config:/usr/share/wazuh-dashboard/config"
    networks:
      - "@@STACK_NAME@@-net"

networks:
  "@@STACK_NAME@@-net":
    driver: bridge

volumes:
  indexer-data:
  manager-data:
